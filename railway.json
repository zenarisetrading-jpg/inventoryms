{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm install --prefix frontend && npm run build --prefix frontend"
  },
  "deploy": {
    "startCommand": "npx serve -s frontend/dist -l $PORT",
    "restartPolicyType": "ON_FAILURE"
  }
}
